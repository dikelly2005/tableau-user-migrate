# =============================================================================
# Tableau Cloud User Migrate Tool v2 — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Required — Tableau Cloud Connection
# ---------------------------------------------------------------------------
SERVER_URL=https://your-site.online.tableau.com
SITE_NAME=your-site-name

# ---------------------------------------------------------------------------
# Required — File Paths
# ---------------------------------------------------------------------------
CSV_LOCATION=./data/user_mappings.csv
LOG_LOCATION=./audit

# ---------------------------------------------------------------------------
# Auth — JWT / Connected App (Primary)
# ---------------------------------------------------------------------------
TABLEAU_CONNECTED_APP_CLIENT_ID=
TABLEAU_CONNECTED_APP_SECRET_ID=
TABLEAU_CONNECTED_APP_SECRET_VALUE=
TABLEAU_USERNAME=

# ---------------------------------------------------------------------------
# Auth — PAT (Fallback)
# ---------------------------------------------------------------------------
TOKEN_NAME=your_pat_name
TOKEN_SECRET=your_pat_secret

# ---------------------------------------------------------------------------
# Optional — API Tuning
# ---------------------------------------------------------------------------
# API_DELAY_MS=100
# MAX_RETRIES=3
# RETRY_BACKOFF_BASE=2.0
# RETRY_JITTER=true
# TOKEN_REFRESH_THRESHOLD_SECONDS=300
# RATE_LIMIT_RPS=10
# DIMENSION_CACHE_TTL_HOURS=24
